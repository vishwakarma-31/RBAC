{
  "name": "rbac-platform",
  "version": "1.0.0",
  "description": "RBAC Authorization Platform",
  "private": true,
  "workspaces": [
    "shared",
    "services/*",
    "dashboard",
    "infrastructure/database"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "mongodb": "^7.2.0",
    "tailwindcss": "^3.4.19",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "jsonwebtoken": "^9.0.0"
  }
}
